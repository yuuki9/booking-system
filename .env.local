# Defaults for local IDE / bootRun with docker-compose.infra.yml
# Copy to .env if your IDE loads .env automatically:
#   cp .env.local .env
#
# Infra:
#   docker compose -f docker-compose.infra.yml up -d

APP_MODE=standard
LOCK_STRATEGY=REDIS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=booking_system
DB_USER=lab
DB_PASSWORD=lab
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
